# Server Configuration
PORT=8000
NODE_ENV=development

# MongoDB Atlas — Cloud Database
# IMPORTANT: Make sure your EC2's outbound access is allowed in Atlas → Network Access
MONGODB_URI=your_mongodb_atlas_connection_string

# JWT Secret Key
JWT_SECRET=your_jwt_secret_here

# JWT Expiration
JWT_EXPIRE=30d

# Frontend URL for CORS — set this to your Route53 domain in production
CLIENT_URL=http://localhost:3000

# Email (Gmail)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── S3 image uploads ──────────────────────────────────────────────────────────
# No AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here — on EC2 the SDK picks up
# credentials automatically from the instance's IAM role.
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name

# Optional — set this once CloudFront is in front of the S3 bucket.
# If left blank, uploaded image URLs will point directly at S3.
CLOUDFRONT_URL=
