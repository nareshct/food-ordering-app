# ── Environment / Secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env
frontend/.env.local

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*

# ── React build output ────────────────────────────────────────────────────────
frontend/build/
backend/build/

# ── Uploads (user-generated content, not source code) ────────────────────────
backend/uploads/avatars/*
backend/uploads/menu/*
backend/uploads/restaurants/*
!backend/uploads/avatars/.gitkeep
!backend/uploads/menu/.gitkeep
!backend/uploads/restaurants/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
/var/log/foodorder/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
