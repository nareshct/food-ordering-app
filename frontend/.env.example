# Frontend Environment Variables
# Copy this file to .env and update the values

# Backend API URL (change port if needed)
REACT_APP_API_URL=http://localhost:8000

# Alternative configurations:
# For production: REACT_APP_API_URL=https://api.yourfoodapp.com
# For different port: REACT_APP_API_URL=http://localhost:8000
# For network access: REACT_APP_API_URL=http://192.168.1.100:5000
